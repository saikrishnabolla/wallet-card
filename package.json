  "description": "Generate a signed Apple Wallet business card pass - networking-friendly QR + tappable fields + Twemoji-color preview mockup.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "sign": "node scripts/sign.mjs",
